# === OmegaAgent Environment Variables ===

# Supabase (structured storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Anthropic (LLM — Haiku default, Sonnet for complex)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Serper (web search)
SERPER_API_KEY=your-serper-key

# Desktop GPU Server (172.16.0.94)
WHISPER_URL=http://172.16.0.94:8000
FISH_TTS_URL=http://172.16.0.94:8080
KOKORO_TTS_URL=http://172.16.0.94:8081

# Obsidian Vault (note agent)
# Inside Docker: ./vault maps to /app/vault (don't change this for Docker)
OBSIDIAN_VAULT_PATH=./vault
# Host path mounted into the container (your actual Obsidian vault subfolder)
VAULT_HOST_PATH=/home/jaeminbbq/Documents/Nexus/note-assistant

# Discord (reminder notifications)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1467261234381459499/mNhVe66nPvggFpba6nbyAaweGS2WJMoszEjzzwyQWbeDE-XFV3PQfD67o2HLGhi8gQDQ

# General
DEFAULT_TIMEZONE=America/Los_Angeles
LOG_LEVEL=INFO
